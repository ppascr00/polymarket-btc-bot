{
  "name": "polymarket-btc-bot",
  "version": "1.0.0",
  "description": "Trading bot for Polymarket BTC 5-minute Up/Down markets",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "backtest": "tsx src/backtest/run.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dashboard": "cd dashboard && npm run dev"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.2.4",
    "better-sqlite3": "^11.7.0",
    "ccxt": "^4.4.0",
    "dotenv": "^16.4.0",
    "ethers": "^5.8.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
